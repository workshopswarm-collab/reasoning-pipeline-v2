{
  "artifact_type": "scae_policy",
  "schema_version": "scae-policy/v1",
  "policy_id": "ads-scae-base-policy/v1",
  "authority_boundary": {
    "live_numeric_forecast_authority": "scae",
    "scae_numeric_aggregation_uses_model": false,
    "model_outputs_may_author_probability": false,
    "model_outputs_may_override_scae": false,
    "synthesis_may_author_probability": false,
    "synthesis_may_override_scae": false,
    "decision_may_author_probability": false,
    "decision_may_replace_probability": false,
    "decision_may_upgrade_forecast_validity": false
  },
  "post_ledger_calibration": {
    "default_method": "identity",
    "live_eligible_methods": [
      "identity"
    ],
    "allow_beta_calibration_live_cutover": false,
    "requires_promoted_policy_pointer_for_non_identity": true
  },
  "calibration_debt": {
    "active": true,
    "allowed_active_values": [
      false,
      true
    ],
    "default_execution_authority_when_active": "low_size_only",
    "tail_probability_floor": 0.02,
    "tail_probability_ceiling": 0.98,
    "minimum_interval_width_logit": 0.5,
    "first_100_trace_completeness_clears_debt": false
  },
  "cap_stack": {
    "per_update_log_odds_cap": 0.35,
    "per_cluster_log_odds_cap": 0.55,
    "per_branch_log_odds_cap": 0.9,
    "total_evidence_log_odds_cap": 1.5,
    "debt_mode_total_evidence_log_odds_cap": 1.0,
    "representative_selector": "policy_bounded_signed_representative_v1",
    "correlated_quality_guard": {
      "enabled": true,
      "repeated_group_min_count": 2,
      "multiplier_ceiling": 0.65
    }
  },
  "prior_reliability": {
    "epsilon": 0.001,
    "base_market_prior_reliability": 0.6,
    "fresh_liquid_reliability_floor": 0.75,
    "stale_thin_reliability_ceiling": 0.35,
    "market_prior_min_reliability": 0.0,
    "market_prior_max_reliability": 0.95,
    "structural_prior_default_reliability": 0.55,
    "neutral_prior_default_reliability": 0.0,
    "tight_spread_threshold": 0.04,
    "wide_spread_threshold": 0.15,
    "deep_depth_threshold": 1000.0,
    "thin_depth_threshold": 100.0,
    "liquid_volume_threshold": 1000.0,
    "thin_volume_threshold": 50.0,
    "active_last_trade_seconds": 300.0,
    "stale_last_trade_seconds": 1800.0
  },
  "market_assimilation": {
    "old_public_evidence_discount_fresh_liquid": 0.25,
    "old_public_evidence_discount_default": 0.5,
    "fresh_or_private_evidence_discount": 1.0,
    "structural_prior_overlap_multiplier": 0.0,
    "base_rate_overlap_multiplier": 0.0
  },
  "evidence_delta_mapping": {
    "schema_version": "scae-evidence-delta-mapping-policy/v1",
    "strength_log_odds": {
      "definitive": 0.45,
      "strong": 0.3,
      "moderate": 0.18,
      "weak": 0.08,
      "none": 0.0,
      "unanswerable": 0.0
    },
    "direction_multipliers": {
      "supports_yes": 1.0,
      "supports_no": -1.0,
      "neutral": 0.0
    },
    "quality_multiplier_source": "evidence_quality_verification_slices.final_quality_multiplier",
    "market_assimilation_multiplier_source": "market_assimilation_context.suggested_signed_delta_multiplier",
    "per_update_cap_source": "cap_stack.per_update_log_odds_cap",
    "missing_verification_behavior": "fail_closed",
    "output_authority": "candidate_ledger_input_only_no_live_forecast_authority"
  },
  "family_diagnostics": {
    "schema_version": "scae-family-diagnostics-policy/v1",
    "sibling_prices_context_only": true,
    "allow_sibling_price_evidence_updates": false,
    "allow_sibling_softmax_reallocation": false,
    "allow_sibling_price_probability_movement": false,
    "exclusive_family_price_tolerance": 0.02
  },
  "probability_taxonomy": {
    "fields": [
      "raw_ledger_probability",
      "post_ledger_probability",
      "debt_adjusted_probability",
      "production_forecast_prob",
      "canonical_probability"
    ],
    "production_source_rule": "debt_adjusted_when_calibration_debt_active_else_post_ledger",
    "canonical_probability_aliases": "production_forecast_prob"
  },
  "validity_and_execution": {
    "forecast_validity_statuses": [
      "invalid_for_forecast",
      "valid_for_forecast_watch_only",
      "valid_for_forecast"
    ],
    "execution_authority_statuses": [
      "forbidden",
      "needs_refresh",
      "watch_only",
      "low_size_only",
      "normal_execution_allowed"
    ],
    "max_execution_authority_by_forecast_validity": {
      "invalid_for_forecast": "forbidden",
      "valid_for_forecast_watch_only": "watch_only",
      "valid_for_forecast": "normal_execution_allowed"
    }
  }
}
